# TODO (you): fill in real values from your LiveKit project.
LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxx
LIVEKIT_API_SECRET=secretxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: change the bind port.
PORT=8787

# Optional: comma-separated allowlist of origins for CORS. "*" = any.
CORS_ORIGIN=*
